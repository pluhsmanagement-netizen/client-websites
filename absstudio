<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>aBs Studios — Atlanta's Best Sound Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Hanken+Grotesk:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#06080C; --bg2:#0A0E15; --panel:#0D121B;
    --line:rgba(126,146,176,.14); --line-2:rgba(126,146,176,.26);
    --ink:#EEF2F9; --soft:#AEB8C8; --mute:#6E7A8C;
    --blue:#2D78FF; --bright:#5BA2FF; --deep:#0E36A8;
    --glow:0 0 22px rgba(63,140,255,.55);
    --maxw:1240px;
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    margin:0; background:var(--bg); color:var(--ink);
    font-family:"Hanken Grotesk",system-ui,sans-serif;
    font-size:17px; line-height:1.6; -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  a{color:inherit;text-decoration:none}
  img{display:block;max-width:100%}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px}
  .ey{font-family:"Space Mono",monospace;font-size:12px;letter-spacing:.32em;
     text-transform:uppercase;color:var(--bright);font-weight:400}
  .neon{height:2px;width:54px;border-radius:2px;
     background:linear-gradient(90deg,var(--bright),var(--blue));box-shadow:var(--glow)}
  h1,h2,h3{margin:0;font-weight:400}
  .display{font-family:"Anton",sans-serif;text-transform:uppercase;line-height:.92;
     letter-spacing:.005em;font-weight:400}

  /* ---------- NAV ---------- */
  .nav{position:fixed;top:0;left:0;right:0;z-index:50;
     display:flex;align-items:center;justify-content:space-between;
     padding:16px 28px;transition:background .35s ease,border-color .35s ease,padding .35s ease;
     border-bottom:1px solid transparent}
  .nav.scrolled{background:rgba(6,8,12,.82);backdrop-filter:blur(14px);
     border-bottom:1px solid var(--line);padding:11px 28px}
  .nav__logo{height:34px;width:auto;filter:drop-shadow(0 1px 10px rgba(0,0,0,.5));transition:height .35s ease}
  .nav.scrolled .nav__logo{height:28px}
  .nav__links{display:flex;gap:34px;align-items:center}
  .nav__links a{font-size:14px;letter-spacing:.04em;color:var(--soft);transition:color .2s}
  .nav__links a:hover{color:var(--ink)}
  .nav__cta{font-family:"Space Mono",monospace;font-size:13px;letter-spacing:.06em;
     padding:10px 18px;border:1px solid var(--line-2);border-radius:100px;color:var(--ink);
     transition:.22s;text-transform:uppercase}
  .nav__cta:hover{border-color:var(--bright);box-shadow:var(--glow);color:#fff}
  .nav__burger{display:none;background:none;border:0;cursor:pointer;padding:6px}
  .nav__burger span{display:block;width:24px;height:2px;background:var(--ink);margin:5px 0;border-radius:2px}

  /* ---------- HERO ---------- */
  .hero{position:relative;min-height:100svh;display:flex;align-items:flex-end;
     padding-bottom:8vh;overflow:hidden}
  .hero__bg{position:absolute;inset:0;z-index:0;background:#000}
  .hero__bg img{width:100%;height:100%;object-fit:cover;opacity:.92;
     transform:scale(1.05);animation:slowzoom 24s ease-out forwards}
  @keyframes slowzoom{to{transform:scale(1)}}
  .hero__scrim{position:absolute;inset:0;z-index:1;
     background:
       radial-gradient(120% 90% at 75% 18%,transparent 0%,rgba(4,6,10,.35) 60%,rgba(4,6,10,.92) 100%),
       linear-gradient(180deg,rgba(6,8,12,.55) 0%,rgba(6,8,12,.05) 26%,rgba(6,8,12,.5) 64%,var(--bg) 99%)}
  .hero__inner{position:relative;z-index:2;width:100%}
  .hero .eyrow{display:flex;align-items:center;gap:16px;margin-bottom:22px}
  .hero h1{font-size:clamp(46px,8.4vw,128px);max-width:14ch;margin:0 0 8px;
     text-shadow:0 4px 40px rgba(0,0,0,.6)}
  .hero h1 .hl{color:transparent;-webkit-text-stroke:1.4px rgba(120,170,255,.85)}
  .hero__sub{max-width:50ch;color:var(--soft);font-size:clamp(16px,1.6vw,19px);margin:18px 0 30px}
  .hero__sub b{color:var(--ink);font-weight:600}
  .hero__cta{display:flex;flex-wrap:wrap;gap:14px;align-items:center}
  .btn{display:inline-flex;align-items:center;gap:10px;font-family:"Space Mono",monospace;
     font-size:14px;letter-spacing:.05em;text-transform:uppercase;padding:15px 26px;border-radius:100px;
     transition:.24s;cursor:pointer;border:1px solid transparent}
  .btn--primary{background:var(--blue);color:#fff;box-shadow:0 8px 30px rgba(45,120,255,.35)}
  .btn--primary:hover{background:#3d86ff;box-shadow:0 8px 40px rgba(45,120,255,.6),var(--glow);transform:translateY(-2px)}
  .btn--ghost{border-color:var(--line-2);color:var(--ink)}
  .btn--ghost:hover{border-color:var(--bright);box-shadow:var(--glow)}
  .hero__rating{display:flex;align-items:center;gap:9px;margin-top:26px;color:var(--soft);font-size:14px}
  .stars{display:inline-flex;gap:2px}
  .stars svg{width:16px;height:16px}

  /* ---------- SECTION SHELL ---------- */
  section{position:relative}
  .sec-head{display:flex;align-items:center;gap:16px;margin-bottom:14px}
  .reveal{opacity:0;transform:translateY(26px);transition:opacity .7s ease,transform .7s ease}
  .reveal.in{opacity:1;transform:none}

  /* ---------- ROOMS ---------- */
  .rooms{padding:clamp(80px,12vh,150px) 0 40px}
  .rooms__intro{max-width:30ch;font-family:"Anton",sans-serif;text-transform:uppercase;
     font-size:clamp(30px,4.4vw,58px);line-height:.98;margin:8px 0 70px}
  .room{display:grid;grid-template-columns:1.05fr .95fr;gap:54px;align-items:center;
     padding:46px 0;border-top:1px solid var(--line)}
  .room--flip .room__media{order:2}
  .room__media{position:relative;border-radius:6px;overflow:hidden;
     box-shadow:0 30px 70px rgba(0,0,0,.55);border:1px solid var(--line)}
  .room__media::after{content:"";position:absolute;inset:0;
     background:linear-gradient(120deg,transparent 55%,rgba(45,120,255,.10))}
  .room__media img{width:100%;aspect-ratio:16/10;object-fit:cover;transition:transform .9s ease}
  .room:hover .room__media img{transform:scale(1.04)}
  .room__tag{position:absolute;top:14px;left:14px;z-index:2;font-family:"Space Mono",monospace;
     font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:#fff;
     background:rgba(6,8,12,.6);backdrop-filter:blur(6px);border:1px solid var(--line-2);
     padding:6px 12px;border-radius:100px}
  .room__name{font-family:"Anton",sans-serif;text-transform:uppercase;
     font-size:clamp(40px,6vw,84px);line-height:.9;margin:0 0 18px}
  .room__rates{display:flex;align-items:baseline;gap:22px;flex-wrap:wrap;margin-bottom:8px}
  .rate{font-family:"Space Mono",monospace}
  .rate__n{font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#fff}
  .rate__l{display:block;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--mute);margin-top:2px}
  .rate--alt .rate__n{color:var(--bright)}
  .room__meta{font-size:15px;color:var(--soft);margin:14px 0 22px;padding-left:14px;
     border-left:2px solid var(--blue)}
  .chips{display:flex;flex-wrap:wrap;gap:8px}
  .chip{font-family:"Space Mono",monospace;font-size:11.5px;letter-spacing:.03em;color:var(--soft);
     border:1px solid var(--line);border-radius:5px;padding:6px 10px;background:rgba(255,255,255,.012)}
  .chip:hover{border-color:var(--line-2);color:var(--ink)}

  /* ---------- STUDIO S BAND ---------- */
  .coming{margin:60px 0 0;border-top:1px solid var(--line);padding-top:60px}
  .coming__card{position:relative;border-radius:8px;overflow:hidden;border:1px solid var(--line);
     min-height:330px;display:flex;align-items:center}
  .coming__card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.5}
  .coming__scrim{position:absolute;inset:0;background:linear-gradient(90deg,rgba(6,8,12,.94),rgba(6,8,12,.55))}
  .coming__body{position:relative;z-index:2;padding:46px clamp(28px,5vw,64px);max-width:720px}
  .coming__name{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(34px,5.4vw,72px);
     line-height:.92;margin:10px 0 16px}
  .coming__name span{color:var(--bright)}
  .coming__meta{color:var(--soft);font-size:15.5px;font-family:"Space Mono",monospace;line-height:1.9}

  /* ---------- AMENITIES ---------- */
  .amen{padding:clamp(80px,12vh,140px) 0}
  .amen__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);
     border:1px solid var(--line);border-radius:8px;overflow:hidden;margin-top:42px}
  .amen__cell{background:var(--bg);padding:34px 30px;display:flex;flex-direction:column;gap:14px;
     transition:background .3s}
  .amen__cell:hover{background:var(--bg2)}
  .amen__ic{width:30px;height:30px;color:var(--bright)}
  .amen__ic svg{width:100%;height:100%;stroke-width:1.5}
  .amen__t{font-size:18px;font-weight:600;color:var(--ink)}
  .amen__d{font-size:14.5px;color:var(--mute);margin:0}

  /* ---------- CREDITS MARQUEE ---------- */
  .credits{padding:36px 0 90px;border-top:1px solid var(--line)}
  .credits .ey{display:block;text-align:center;margin-bottom:26px}
  .marquee{position:relative;overflow:hidden;mask:linear-gradient(90deg,transparent,#000 12%,#000 88%,transparent)}
  .marquee__t{display:inline-flex;gap:54px;white-space:nowrap;animation:scroll 34s linear infinite;
     font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(26px,3.4vw,46px);
     color:transparent;-webkit-text-stroke:1px rgba(174,184,200,.4)}
  .marquee__t span{transition:.3s}
  .marquee:hover .marquee__t{animation-play-state:paused}
  .marquee__t span:hover{-webkit-text-stroke:1px var(--bright);color:rgba(91,162,255,.12)}
  @keyframes scroll{to{transform:translateX(-50%)}}

  /* ---------- BOOKING BAND ---------- */
  .book{padding:clamp(70px,10vh,120px) 0;border-top:1px solid var(--line);
     background:radial-gradient(80% 130% at 50% 0%,rgba(20,54,168,.22),transparent 70%)}
  .book__in{display:grid;grid-template-columns:1.1fr .9fr;gap:50px;align-items:center}
  .book h2{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:clamp(38px,6vw,80px);line-height:.92}
  .book p{color:var(--soft);max-width:42ch;margin:18px 0 0}
  .book__policy{font-family:"Space Mono",monospace;font-size:13px;color:var(--bright);letter-spacing:.04em;
     margin-top:22px;line-height:2}
  .book__actions{display:flex;flex-direction:column;gap:14px}
  .book__actions .btn{justify-content:center;font-size:15px;padding:18px 26px}
  .book__note{font-size:13px;color:var(--mute);text-align:center;font-family:"Space Mono",monospace}

  /* ---------- FOOTER ---------- */
  footer{border-top:1px solid var(--line);background:var(--bg2);padding:70px 0 34px}
  .foot__grid{display:grid;grid-template-columns:1.3fr 1fr 1fr 1.1fr;gap:40px}
  .foot__logo{height:42px;width:auto;margin-bottom:20px;opacity:.95}
  .foot__about{color:var(--mute);font-size:14.5px;max-width:34ch}
  .foot h4{font-family:"Space Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;
     color:var(--mute);font-weight:400;margin:0 0 18px}
  .foot ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:13px}
  .foot li{display:flex;gap:11px;align-items:flex-start;font-size:14.5px;color:var(--soft)}
  .foot li svg{width:17px;height:17px;flex:0 0 17px;color:var(--bright);margin-top:2px;stroke-width:1.6}
  .foot a:hover{color:var(--ink)}
  .foot__rate{display:flex;align-items:center;gap:10px;margin-bottom:8px}
  .foot__rate .num{font-family:"Space Mono",monospace;font-weight:700;font-size:20px;color:#fff}
  .foot__rev{font-size:13.5px;color:var(--mute)}
  .foot__soc{display:flex;gap:12px;margin-top:18px}
  .foot__soc a{width:40px;height:40px;border:1px solid var(--line-2);border-radius:100px;
     display:flex;align-items:center;justify-content:center;transition:.22s}
  .foot__soc a:hover{border-color:var(--bright);box-shadow:var(--glow)}
  .foot__soc svg{width:18px;height:18px;color:var(--ink)}
  .foot__bar{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;
     margin-top:54px;padding-top:24px;border-top:1px solid var(--line);
     font-size:12.5px;color:var(--mute);font-family:"Space Mono",monospace;letter-spacing:.04em}

  /* ---------- RESPONSIVE ---------- */
  @media(max-width:900px){
    .nav__links{display:none}
    .nav__burger{display:block}
    .room,.book__in{grid-template-columns:1fr;gap:30px}
    .room--flip .room__media{order:0}
    .room__media{order:0}
    .amen__grid{grid-template-columns:1fr 1fr}
    .foot__grid{grid-template-columns:1fr 1fr;gap:34px}
  }
  @media(max-width:560px){
    body{font-size:16px}
    .wrap{padding:0 20px}
    .nav,.nav.scrolled{padding:12px 20px}
    .amen__grid{grid-template-columns:1fr}
    .foot__grid{grid-template-columns:1fr}
    .hero__cta{flex-direction:column;align-items:stretch}
    .btn{justify-content:center}
  }
  @media(prefers-reduced-motion:reduce){
    *{animation:none!important;transition:none!important;scroll-behavior:auto!important}
    .reveal{opacity:1;transform:none}
    .hero__bg img{transform:none}
  }
  :focus-visible{outline:2px solid var(--bright);outline-offset:3px;border-radius:4px}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav" id="nav">
  <a href="#top" aria-label="aBs Studios home"><img class="nav__logo" src="data:image/png;base64," alt="aBs Studios"></a>
  <div class="nav__links">
    <a href="#rooms">Rooms</a>
    <a href="#amenities">The Space</a>
    <a href="#book">Rates</a>
    <a href="#contact">Contact</a>
  </div>
  <a href="#book" class="nav__cta">Book a session</a>
  <button class="nav__burger" id="burger" aria-label="Menu"><span></span><span></span></button>
</nav>

<!-- HERO -->
<header class="hero" id="top">
  <div class="hero__bg"><img src="data:image/jpeg;base64," alt="aBs Studios control room"></div>
  <div class="hero__scrim"></div>
  <div class="hero__inner">
    <div class="wrap">
      <div class="eyrow"><span class="neon"></span><span class="ey">Atlanta's Best Sound Studio · SE ATL</span></div>
      <h1 class="display">Where the city comes to <span class="hl">record</span></h1>
      <p class="hero__sub">Two flagship rooms. In-house engineers. <b>UPS-backed power so you never lose a take.</b> Open 24 hours in Southeast Atlanta.</p>
      <div class="hero__cta">
        <a href="#book" class="btn btn--primary">Book a session</a>
        <a href="tel:+14045004724" class="btn btn--ghost">Call (404) 500-4724</a>
      </div>
      <div class="hero__rating">
        <span class="stars" id="heroStars"></span>
        <span><b style="color:#fff">4.5</b> · 81 Google reviews</span>
      </div>
    </div>
  </div>
</header>

<!-- ROOMS -->
<section class="rooms" id="rooms">
  <div class="wrap">
    <div class="sec-head reveal"><span class="neon"></span><span class="ey">The Rooms</span></div>
    <h2 class="rooms__intro reveal">Built for the take, wired for the vibe.</h2>

    <!-- Studio A -->
    <article class="room reveal">
      <div class="room__media"><span class="room__tag">Flagship · A Room</span><img src="data:image/jpeg;base64," alt="Studio A control room"></div>
      <div class="room__body">
        <h3 class="room__name">Studio A</h3>
        <div class="room__rates">
          <div class="rate"><span class="rate__n">$75<small style="font-size:.5em">/hr</small></span><span class="rate__l">With engineer</span></div>
          <div class="rate rate--alt"><span class="rate__n">$50<small style="font-size:.5em">/hr</small></span><span class="rate__l">Without</span></div>
        </div>
        <p class="room__meta">333 sq ft control room + 300 sq ft lounge · 8′×8′ vocal booth · 20kW playback</p>
        <div class="chips">
          <span class="chip">Apple Mac Pro</span><span class="chip">Neumann U-87</span>
          <span class="chip">Avalon 737</span><span class="chip">BAE 1073MP</span>
          <span class="chip">Tube-Tech CL1B</span><span class="chip">EL Distressor</span>
          <span class="chip">UAD Apollo 8</span><span class="chip">Yamaha HS8</span>
        </div>
      </div>
    </article>

    <!-- Studio B -->
    <article class="room room--flip reveal">
      <div class="room__media"><span class="room__tag">Vocal Room · B</span><img src="data:image/jpeg;base64," alt="Studio B vocal booth"></div>
      <div class="room__body">
        <h3 class="room__name">Studio B</h3>
        <div class="room__rates">
          <div class="rate"><span class="rate__n">$60<small style="font-size:.5em">/hr</small></span><span class="rate__l">With engineer</span></div>
          <div class="rate rate--alt"><span class="rate__n">$35<small style="font-size:.5em">/hr</small></span><span class="rate__l">Without</span></div>
        </div>
        <p class="room__meta">140 sq ft · up to 3 guests · 60 sq ft vocal booth · 6kW playback</p>
        <div class="chips">
          <span class="chip">Apple Mac Mini</span><span class="chip">Warm WA-87</span>
          <span class="chip">WA73-EQ</span><span class="chip">WA-76</span>
          <span class="chip">UAD Apollo x6</span><span class="chip">Yamaha + 15″ sub</span>
          <span class="chip">UPS backup</span>
        </div>
      </div>
    </article>

    <!-- Studio S -->
    <div class="coming reveal">
      <div class="coming__card">
        <img src="data:image/jpeg;base64," alt="Studio S">
        <div class="coming__scrim"></div>
        <div class="coming__body">
          <div class="eyrow" style="display:flex;align-items:center;gap:14px"><span class="neon"></span><span class="ey">Opening soon</span></div>
          <h3 class="coming__name">Studio S <span>— coming soon</span></h3>
          <p class="coming__meta">700 sq ft · up to 10 guests · 10′×12′ vocal booth<br>Genelec 8351 · Avid 32-channel board · Manley Reference · UA 1176</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- AMENITIES -->
<section class="amen" id="amenities">
  <div class="wrap">
    <div class="sec-head reveal"><span class="neon"></span><span class="ey">The Space</span></div>
    <h2 class="display reveal" style="font-size:clamp(30px,4.4vw,56px);max-width:18ch">More than a room — a place to actually create.</h2>
    <div class="amen__grid reveal">
      <div class="amen__cell">
        <span class="amen__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
        <span class="amen__t">Open 24 hours</span><p class="amen__d">Day sessions, late nights, weekends. The door's open whenever the idea hits.</p>
      </div>
      <div class="amen__cell">
        <span class="amen__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 14a4 4 0 0 0 4-4V6a4 4 0 0 0-8 0v4a4 4 0 0 0 4 4Z"/><path d="M6 10a6 6 0 0 0 12 0M12 18v3M9 21h6"/></svg></span>
        <span class="amen__t">In-house engineers</span><p class="amen__d">Skilled engineers on every session — or bring your own. Your sound, dialed in.</p>
      </div>
      <div class="amen__cell">
        <span class="amen__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z"/></svg></span>
        <span class="amen__t">UPS-backed power</span><p class="amen__d">Battery backup on every room. A flicker never costs you the take you just nailed.</p>
      </div>
      <div class="amen__cell">
        <span class="amen__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 11v6a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-6M4 11V9a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v2M4 11h16M7 18v2M17 18v2"/></svg></span>
        <span class="amen__t">Artist lounge</span><p class="amen__d">A 300 sq ft lounge to write, reset, and keep the energy right between cuts.</p>
      </div>
      <div class="amen__cell">
        <span class="amen__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4M7 9l2 2 3-4 2 3 2-2"/></svg></span>
        <span class="amen__t">Content-ready</span><p class="amen__d">Lit for the camera. Walk out with footage as clean as the record.</p>
      </div>
      <div class="amen__cell">
        <span class="amen__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M8 2v4M16 2v4M3 9h18"/><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M9 14l2 2 4-4"/></svg></span>
        <span class="amen__t">By appointment</span><p class="amen__d">Lock your slot ahead by phone or DM. Walk-ins welcome when a room is free.</p>
      </div>
    </div>
  </div>
</section>

<!-- CREDITS -->
<section class="credits">
  <span class="ey">Sessions have included</span>
  <div class="marquee">
    <div class="marquee__t" id="marq">
      <span>Lil Baby</span><span>·</span><span>21 Savage</span><span>·</span><span>Offset</span><span>·</span><span>NBA YoungBoy</span><span>·</span><span>Playboi Carti</span><span>·</span><span>Kandi Burruss</span><span>·</span>
    </div>
  </div>
</section>

<!-- BOOKING -->
<section class="book" id="book">
