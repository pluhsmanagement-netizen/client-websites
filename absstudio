  // mobile menu (simple scroll to book)
  document.getElementById('burger').addEventListener('click',()=>location.hash='#book');
  // year
  document.getElementById('yr').textContent=new Date().getFullYear();
  // stars
  const starSVG='<svg viewBox="0 0 24 24" fill="#5BA2FF"><path d="m12 2 3 6.9 7.5.6-5.7 5 1.8 7.4L12 18l-6.4 3.9 1.8-7.4-5.7-5 7.5-.6L12 2Z"/></svg>';
  const halfSVG='<svg viewBox="0 0 24 24"><defs><linearGradient id="hg"><stop offset="50%" stop-color="#5BA2FF"/><stop offset="50%" stop-color="#2a3340"/></linearGradient></defs><path fill="url(#hg)" d="m12 2 3 6.9 7.5.6-5.7 5 1.8 7.4L12 18l-6.4 3.9 1.8-7.4-5.7-5 7.5-.6L12 2Z"/></svg>';
  function fillStars(el){if(!el)return;el.innerHTML=starSVG.repeat(4)+halfSVG;}
  fillStars(document.getElementById('heroStars'));
  fillStars(document.getElementById('footStars'));
  // duplicate marquee for seamless loop
  const m=document.getElementById('marq'); if(m) m.innerHTML+=m.innerHTML;
  // reveal on scroll
  const io=new IntersectionObserver((es)=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}}),{threshold:.12});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>
